# Configuración de alertas — Wurth Argentina
# Copiar este archivo a .env y completar con valores reales.
# NUNCA commitear el .env con datos reales.

# ── Teams (recomendado) ────────────────────────────────────────────────────────
# Crear un flujo en Power Automate:
#   Nuevo flujo → "Publicar en un canal de Teams cuando se recibe una solicitud HTTP"
#   Copiar la URL generada aquí.
# O usar un conector Incoming Webhook legacy (canal → Conectores → Incoming Webhook).
WURTH_TEAMS_WEBHOOK_URL=https://prod-XX.westus.logic.azure.com/workflows/...

# ── Email via SMTP (alternativa o adicional a Teams) ──────────────────────────
# Para Office 365 / Outlook corporativo:
WURTH_SMTP_HOST=smtp.office365.com
WURTH_SMTP_PORT=587
WURTH_SMTP_USER=alertas-rotacion@wurth.com.ar
WURTH_SMTP_PASSWORD=

# Destinatarios separados por coma (RRHH, gerencia, supervisores, etc.)
WURTH_EMAIL_TO=rrhh@wurth.com.ar,gerencia@wurth.com.ar
